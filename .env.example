# --- Base de données (SQLite par défaut, PostgreSQL en production) ---
ACP_DATABASE_URL=sqlite:///./acp.db
# ACP_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/acp

# --- URLs inter-services ---
ACP_API_URL=http://localhost:8000
ACP_EVENT_SERVICE_URL=http://localhost:8001
ACP_PROVIDER_GATEWAY_URL=http://localhost:8002

# --- Worker distant ---
ACP_WORKER_POLL_INTERVAL=2.0
ACP_ORCHESTRATOR_PROVIDER=mock
# Secret d'enrôlement partagé uniquement pendant `worker register` (à remplacer)
ACP_WORKER_REGISTRATION_TOKEN=change-me-with-a-random-secret
# Pepper serveur optionnel : ne pas le configurer sur la machine worker
ACP_WORKER_TOKEN_PEPPER=
# ACP_WORKER_NAME=render-node-01
# ACP_WORKER_MAX_CONCURRENCY=1
# ACP_WORKER_STATE_DIR=C:\Users\me\.agent-company-worker
# ACP_WORKER_SIMULATION=1

# --- Répertoire des plugins ---
ACP_PLUGINS_DIR=./plugins

# --- Provider Hermes (service externe optionnel, jamais requis) ---
HERMES_BASE_URL=
HERMES_SERVICE_TOKEN=
HERMES_TIMEOUT_SECONDS=30
HERMES_MAX_RETRIES=2
