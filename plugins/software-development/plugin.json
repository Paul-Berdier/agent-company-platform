{
  "module": "software-development",
  "version": "0.1.0",
  "description": "Département Software Engineering : rôles, workflow de livraison, open space de dev.",
  "departments": [
    {
      "department_type": "software-engineering",
      "name": "Software Engineering",
      "office_theme": "dev-floor",
      "stations": [
        { "id": "dev-desk-1", "name": "Dev Desk 1", "kind": "desk", "x": 1, "y": 3 },
        { "id": "dev-desk-2", "name": "Dev Desk 2", "kind": "desk", "x": 4, "y": 3 },
        { "id": "dev-desk-3", "name": "Dev Desk 3", "kind": "desk", "x": 7, "y": 3 },
        { "id": "dev-desk-4", "name": "Dev Desk 4", "kind": "desk", "x": 1, "y": 6 },
        { "id": "dev-desk-5", "name": "Dev Desk 5", "kind": "desk", "x": 4, "y": 6 },
        { "id": "dev-desk-6", "name": "Dev Desk 6", "kind": "desk", "x": 7, "y": 6 },
        { "id": "review-corner", "name": "Review Corner", "kind": "whiteboard", "x": 4, "y": 1 },
        { "id": "coffee-corner", "name": "Coffee Corner", "kind": "coffee-machine", "x": 9, "y": 1 },
        { "id": "plant-1", "name": "Plant", "kind": "plant", "x": 0, "y": 1 },
        { "id": "plant-2", "name": "Plant", "kind": "plant", "x": 11, "y": 4 },
        { "id": "water-cooler", "name": "Water Cooler", "kind": "water-cooler", "x": 0, "y": 4 },
        { "id": "ci-rack", "name": "CI Server Rack", "kind": "server-rack", "x": 10, "y": 6 }
      ],
      "available_animations": ["sit", "type", "walk", "think", "coffee", "point"],
      "status_mapping": {
        "idle": "coffee",
        "thinking": "think",
        "working": "type",
        "reviewing": "point",
        "blocked": "sit",
        "offline": "away"
      },
      "roles": [
        { "id": "frontend-developer", "name": "Frontend Developer", "capabilities": ["code", "review"], "sprite": "dev" },
        { "id": "backend-developer", "name": "Backend Developer", "capabilities": ["code", "review", "database"], "sprite": "dev" },
        { "id": "qa-engineer", "name": "QA Engineer", "capabilities": ["test", "review"], "sprite": "qa" },
        { "id": "tech-lead", "name": "Tech Lead", "capabilities": ["plan", "review", "code"], "sprite": "lead" }
      ]
    }
  ],
  "capabilities": [
    { "id": "code", "name": "Écrire du code", "required_providers": ["git", "filesystem"] },
    { "id": "test", "name": "Tester", "required_providers": ["cicd"] },
    { "id": "review", "name": "Relire du code", "required_providers": ["git"] },
    { "id": "database", "name": "Gérer les bases de données", "required_providers": ["databases"] }
  ],
  "workflows": [
    {
      "id": "web-delivery",
      "name": "Livraison web",
      "project_types": ["web-app", "automation"],
      "steps": [
        { "id": "spec", "name": "Spécifier", "role_id": "tech-lead" },
        { "id": "implement", "name": "Implémenter", "role_id": "backend-developer" },
        { "id": "test", "name": "Tester", "role_id": "qa-engineer", "validator": "tests-pass" },
        { "id": "review", "name": "Relire", "role_id": "tech-lead", "validator": "review-approved" }
      ]
    }
  ],
  "indicators": [
    { "id": "open-tasks", "name": "Tâches ouvertes" },
    { "id": "review-queue", "name": "File de review" }
  ]
}
